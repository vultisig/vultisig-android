root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Kotlin — matches ktfmt kotlinLangStyle() / KOTLIN_OFFICIAL
[*.{kt,kts}]
indent_size = 4
continuation_indent_size = 4
max_line_length = 100

[*.xml]
indent_size = 4

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
